# Optional — only needed for the §11 LLM message check.
# The core Campaign Canvas app works fully without these.
# Set these as service variables in Railway (never commit a real key).

# Your Anthropic API key. Without it, the message-check endpoint returns a
# friendly "not enabled" response and the rest of the app is unaffected.
ANTHROPIC_API_KEY=

# Optional model override for the message check. Defaults to claude-opus-4-8.
# ANTHROPIC_MODEL=claude-opus-4-8

# PORT is injected automatically by Railway; only set it for local `npm start`.
# PORT=3000
