{
  "name": "campaign-canvas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Map your launch on one canvas, simulate every channel, and see the users before you spend.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
